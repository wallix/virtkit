# virtkit kernel removals overlay (options the base config fragment enables that
# virtkit does not use). Merged AFTER kernel-fragment.config (kernel/Dockerfile) so
# it overrides those defaults, and the divergence stays auditable and survives a
# re-vendor of the base fragment. olddefconfig re-resolves deps afterwards, so the Dockerfile
# asserts a representative subset stayed disabled (a dependency could resurrect
# one) — same spirit as its load-bearing-options check.
#
# Every symbol here is disabled because virtkit does not use the feature AT ALL
# (verified against the host's cloud-hypervisor invocation: --console --cpus
# --disk --fs --kernel --memory --serial --vsock --balloon; no --pmem, no
# --device passthrough, no SGX, no SCSI, virtio-blk root=/dev/vda ext4, shares
# over virtio-fs not 9p). These are the zero-workload-risk cuts; netfilter/IPVS,
# hotplug, FIPS/EXPERT and SCSI are deliberately NOT here (Tier 2/3 — gate those
# behind the CI job suite). After building, measure: vmlinux size, boot time, and
# kernel RSS per VM.

# ---- Mellanox ConnectX (physical NIC drivers) ----
# Guests use virtio-net; no passthrough of physical Mellanox hardware. mlx5 is a
# large driver — likely the single biggest size win here.
# CONFIG_NET_VENDOR_MELLANOX is not set
# CONFIG_MLX5_CORE is not set
# CONFIG_MLX5_CORE_EN is not set
# CONFIG_MLX5_EN_ARFS is not set
# CONFIG_MLX5_EN_RXNFC is not set

# ---- VFIO / IOMMU device passthrough ----
# virtkit passes no --device to cloud-hypervisor, so there is no PCI passthrough.
# (VIRTIO_IOMMU / IOMMU_SUPPORT are left alone — virtio plumbing, not passthrough.)
# CONFIG_VFIO is not set
# CONFIG_VFIO_PCI is not set
# CONFIG_INTEL_IOMMU is not set
# CONFIG_IRQ_REMAP is not set

# ---- Intel SGX (confidential-compute enclaves) ----
# virtkit is the non-confidential set; no enclave support is used.
# CONFIG_X86_SGX is not set

# ---- NVDIMM / pmem / DAX ----
# The base config maps rootfs over pmem+DAX; virtkit boots root=/dev/vda ext4 over virtio-blk
# and passes no --pmem. FUSE_DAX has no host counterpart either: current
# cloud-hypervisor states DAX "is not available" (not stable from the daemon side),
# and the bundled virtiofsd does not implement the DAX window. Re-add CONFIG_FUSE_DAX
# (and a virtio-fs dax=on path) only if CH+virtiofsd ever ship stable DAX — it would
# let read-only shares (ci-tools) map the host page cache once across all VMs.
# CONFIG_BLK_DEV_PMEM is not set
# CONFIG_VIRTIO_PMEM is not set
# CONFIG_LIBNVDIMM is not set
# CONFIG_BTT is not set
# CONFIG_ND_PFN is not set
# CONFIG_NVDIMM_PFN is not set
# CONFIG_NVDIMM_DAX is not set
# CONFIG_DAX is not set
# CONFIG_FS_DAX is not set
# CONFIG_FUSE_DAX is not set

# ---- CIFS / SMB client ----
# Shares are virtio-fs; no SMB mounts. DNS_RESOLVER only served the CIFS/NFS upcalls.
# CONFIG_CIFS is not set
# CONFIG_CIFS_STATS2 is not set
# CONFIG_CIFS_UPCALL is not set
# CONFIG_CIFS_XATTR is not set
# CONFIG_CIFS_DFS_UPCALL is not set
# CONFIG_CIFS_SWN_UPCALL is not set
# CONFIG_DNS_RESOLVER is not set

# ---- 9p (Plan 9 filesystem) ----
# Upstream heritage; virtkit uses virtio-fs instead (CONFIG_VIRTIO_FS, kept).
# CONFIG_NET_9P is not set
# CONFIG_NET_9P_VIRTIO is not set
# CONFIG_9P_FS is not set
# CONFIG_9P_FS_POSIX_ACL is not set
# CONFIG_9P_FS_SECURITY is not set

# ---- XFS ----
# Rootfs and images are ext4/overlayfs; XFS is unused.
# CONFIG_XFS_FS is not set

# ---- Non-x86 XZ BCJ decoders ----
# Pointless on an x86_64-only guest. XZ_DEC and XZ_DEC_X86 are kept.
# CONFIG_XZ_DEC_POWERPC is not set
# CONFIG_XZ_DEC_ARM is not set
# CONFIG_XZ_DEC_ARMTHUMB is not set
# CONFIG_XZ_DEC_ARM64 is not set
# CONFIG_XZ_DEC_SPARC is not set
# CONFIG_XZ_DEC_RISCV is not set

# ---- Virtual terminal / VGA console ----
# Guests run a serial console (console=ttyS0, --serial/--console); no VT/VGA.
# Disabling VT cascades to VT_CONSOLE/CONSOLE_TRANSLATIONS, listed for intent.
# CONFIG_VT is not set
# CONFIG_VT_CONSOLE is not set
# CONFIG_CONSOLE_TRANSLATIONS is not set
# CONFIG_VGA_ARB is not set

# =============================================================================
# Tier 2 — clean removals (FIPS, SCSI, debug). Low workload risk.
# =============================================================================

# ---- FIPS crypto + boot-time crypto self-tests ----
# The base config enables CRYPTO_FIPS (chain: FIPS -> CRYPTO_SELFTESTS -> EXPERT), which also
# runs algorithm self-tests on every boot. virtkit has no FIPS-compliance need.
# NOTE: CONFIG_EXPERT is deliberately LEFT ON — the base fragment relies on it to
# expose the ~30 options it manually restores (lines under crypto.conf). Turning
# EXPERT off is a separate, riskier change and is NOT done here.
# CONFIG_CRYPTO_FIPS is not set
# CONFIG_CRYPTO_SELFTESTS is not set
# CONFIG_CRYPTO_ANSI_CPRNG is not set

# ---- SCSI stack ----
# virtkit boots root=/dev/vda over virtio-blk (--disk) and uses no virtio-scsi.
# Disabling CONFIG_SCSI cascades to the rest; listed explicitly for audit.
# CONFIG_SCSI is not set
# CONFIG_SCSI_LOWLEVEL is not set
# CONFIG_SCSI_VIRTIO is not set
# CONFIG_BLK_DEV_SD is not set

# ---- Debug instrumentation (size + boot cost) ----
# DEBUG_FS is the riskiest of these — some BPF/tracing/driver paths expect debugfs
# to be mountable; if a guest tool misbehaves, this is the first to re-add.
# STACKTRACE may be re-selected by another enabled option; verify it actually drops.
# CONFIG_SLUB_DEBUG is not set
# CONFIG_DEBUG_MEMORY_INIT is not set
# CONFIG_DEBUG_BUGVERBOSE is not set
# CONFIG_DEBUG_FS is not set
# CONFIG_STACKTRACE is not set

# =============================================================================
# Tier 3 — non-core IP filtering. HIGHER RISK: docker-in-docker and CI job
# iptables/nftables rulesets depend on a specific subset of netfilter. This block
# keeps that core (see keep-list) and removes only the exotic long tail. It MUST
# be validated against the docker-in-docker + networking CI job suite, and is best
# landed as its OWN commit so a regression is trivial to bisect/revert.
#
# KEEP (core, NOT removed here): NF_CONNTRACK, NF_NAT, NF_NAT_REDIRECT,
#   NF_DEFRAG_IPV4/6, NF_CONNTRACK_FTP(+NAT_FTP); IP_NF_IPTABLES/FILTER/NAT/MANGLE/
#   RAW, IP_NF_TARGET_REJECT/MASQUERADE/REDIRECT/NETMAP; IP6 equivalents;
#   NF_TABLES(+INET/IPV4/IPV6/BRIDGE/NETDEV), NFT_CT/NAT/MASQ/REDIR/LIMIT/LOG/
#   REJECT*/FIB*/COMPAT/CHAIN_NAT; BRIDGE_NETFILTER; XT core: XT_MARK, XT_CONNMARK,
#   XT_NAT, XT_TARGET_CONNMARK/CT/LOG/TCPMSS, XT_MATCH_ADDRTYPE/CONNTRACK/CONNMARK/
#   STATE/MARK/MULTIPORT/COMMENT/LIMIT/PHYSDEV/IPRANGE/OWNER/TCPMSS.
# -----------------------------------------------------------------------------

# ---- IPVS / LVS load balancer (whole subsystem) ----
# A CI runner VM is not a kube-proxy/LVS node.
# CONFIG_IP_VS is not set
# CONFIG_IP_VS_PROTO_TCP is not set
# CONFIG_IP_VS_PROTO_UDP is not set
# CONFIG_IP_VS_PROTO_AH_ESP is not set
# CONFIG_IP_VS_PROTO_ESP is not set
# CONFIG_IP_VS_PROTO_AH is not set
# CONFIG_IP_VS_PROTO_SCTP is not set
# CONFIG_IP_VS_RR is not set
# CONFIG_IP_VS_WRR is not set
# CONFIG_IP_VS_LC is not set
# CONFIG_IP_VS_WLC is not set
# CONFIG_IP_VS_FO is not set
# CONFIG_IP_VS_OVF is not set
# CONFIG_IP_VS_LBLC is not set
# CONFIG_IP_VS_LBLCR is not set
# CONFIG_IP_VS_DH is not set
# CONFIG_IP_VS_SH is not set
# CONFIG_IP_VS_SED is not set
# CONFIG_IP_VS_NQ is not set
# CONFIG_IP_VS_FTP is not set
# CONFIG_IP_VS_NFCT is not set
# CONFIG_IP_VS_PE_SIP is not set

# ---- ipset (whole subsystem; XT_SET depends on it) ----
# Used by firewalld/ipset rules; not core to docker or CI runners.
# CONFIG_IP_SET is not set
# CONFIG_IP_SET_BITMAP_IP is not set
# CONFIG_IP_SET_BITMAP_IPMAC is not set
# CONFIG_IP_SET_BITMAP_PORT is not set
# CONFIG_IP_SET_HASH_IP is not set
# CONFIG_IP_SET_HASH_IPMARK is not set
# CONFIG_IP_SET_HASH_IPPORT is not set
# CONFIG_IP_SET_HASH_IPPORTIP is not set
# CONFIG_IP_SET_HASH_IPPORTNET is not set
# CONFIG_IP_SET_HASH_MAC is not set
# CONFIG_IP_SET_HASH_NETPORTNET is not set
# CONFIG_IP_SET_HASH_NET is not set
# CONFIG_IP_SET_HASH_NETNET is not set
# CONFIG_IP_SET_HASH_NETPORT is not set
# CONFIG_IP_SET_HASH_NETIFACE is not set
# CONFIG_IP_SET_LIST_SET is not set
# CONFIG_NETFILTER_XT_SET is not set

# ---- Exotic conntrack ALG helpers + their NAT (legacy protocols) ----
# FTP (+NAT_FTP) is kept as the lowest-risk common helper.
# CONFIG_NF_CONNTRACK_AMANDA is not set
# CONFIG_NF_CONNTRACK_H323 is not set
# CONFIG_NF_CONNTRACK_IRC is not set
# CONFIG_NF_CONNTRACK_BROADCAST is not set
# CONFIG_NF_CONNTRACK_NETBIOS_NS is not set
