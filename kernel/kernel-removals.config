# =============================================================================
# Group 2 — VMM-agnostic dead weight + features moved to per-bundle kernels.
# A guest microVM neither governs the physical CPU's frequency/thermals nor
# spans NUMA nodes. WireGuard / IPsec / VXLAN / tunnels are out because virtkit
# drives networking from its own userspace stack (the switch); any job that
# needs in-guest WireGuard/IPsec/VXLAN ships its OWN kernel (per-bundle vmlinuz).
# All confirmed absent from libkrunfw's minimal config too.
# =============================================================================

# ---- CPU frequency scaling (the hypervisor owns the physical CPU) ----
# Disabling CPU_FREQ cascades its governors; X86_INTEL_PSTATE listed for intent.
# CONFIG_THERMAL is deliberately NOT removed: on x86+ACPI (kept for cloud-hypervisor)
# it is force-selected, so olddefconfig resurrects it — leave it on.
# CONFIG_CPU_FREQ is not set
# CONFIG_X86_INTEL_PSTATE is not set

# ---- NUMA (single-node microVM; X86_64_ACPI_NUMA cascades off) ----
# CONFIG_NUMA is not set

# ---- virtio-mem hotplug + virtual IOMMU (we use --balloon, no passthrough) ----
# CONFIG_VIRTIO_MEM is not set
# CONFIG_VIRTIO_IOMMU is not set

# ---- IPsec / XFRM (no in-guest IPsec; WireGuard does NOT use XFRM) ----
# CONFIG_XFRM_USER is not set
# CONFIG_XFRM is not set
# CONFIG_INET_ESP is not set

# ---- WireGuard (networking is host-side via the switch). Cascades out its
#      crypto: chacha20poly1305 / curve25519 / blake2s / poly1305. ----
# CONFIG_WIREGUARD is not set

# ---- VXLAN + L2/L3 tunnels (no overlay networking inside the guest) ----
# CONFIG_VXLAN is not set
# CONFIG_NET_IP_TUNNEL is not set
# CONFIG_NET_UDP_TUNNEL is not set
